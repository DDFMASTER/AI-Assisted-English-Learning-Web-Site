<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <!-- ===== 控制台输出（开发调试用） ===== -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <!-- ===== 文件输出（按天滚动，自动清理） ===== -->
    <!--
        文件位置说明：
        - ${catalina.base} 是 Tomcat 安装目录（如 C:\tomcat 或 /opt/tomcat）
        - 最终路径：${catalina.base}/logs/aael.log
        - 若需自定义路径，改为绝对路径即可（如 /var/log/aael/aael.log）
        - Windows 示例：C:/logs/aael/aael.log
    -->
    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <!-- 当前日志文件 -->
        <file>${catalina.base}/logs/aael.log</file>

        <!-- 滚动策略：每天一个新文件，自动压缩旧文件 -->
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <!-- 归档文件名格式：aael.2026-07-05.log -->
            <fileNamePattern>${catalina.base}/logs/aael.%d{yyyy-MM-dd}.log</fileNamePattern>

            <!-- 最多保留 30 天历史，超过自动删除 -->
            <maxHistory>30</maxHistory>

            <!-- 可选：限制总大小（超过后删除最旧文件） -->
            <totalSizeCap>500MB</totalSizeCap>
        </rollingPolicy>

        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <!-- ===== 错误日志单独输出 ===== -->
    <appender name="ERROR_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${catalina.base}/logs/aael-error.log</file>
        <filter class="ch.qos.logback.classic.filter.ThresholdFilter">
            <level>ERROR</level>
        </filter>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>${catalina.base}/logs/aael-error.%d{yyyy-MM-dd}.log</fileNamePattern>
            <maxHistory>60</maxHistory>
        </rollingPolicy>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <!-- 应用日志级别 -->
    <logger name="Utils" level="INFO" />
    <logger name="Service" level="INFO" />
    <logger name="DAO" level="WARN" />
    <logger name="Servlet" level="INFO" />
    <logger name="Filter" level="INFO" />
    <logger name="Listener" level="INFO" />

    <!-- 根日志：同时输出到控制台和文件 -->
    <root level="INFO">
        <appender-ref ref="CONSOLE" />
        <appender-ref ref="FILE" />
        <appender-ref ref="ERROR_FILE" />
    </root>
</configuration>
